# Copy to .env and fill in. Never commit .env.
# server.js also loads ../bot/.env for BOT_TOKEN and kitchen vars.

# Required for production — use a long random string
JWT_SECRET=

JWT_EXPIRES_IN=7d

# Admin dashboard login (create restaurants, etc.)
ADMIN_EMAIL=
ADMIN_PASSWORD=

PORT=3000

# Optional: duplicate bot vars here if you do not use bot/.env on the server
# BOT_TOKEN=
# KITCHEN_GROUP_ID=
# SKIP_TELEGRAM_KITCHEN=true
